{
  "name": "character-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "next:dev": "next dev",
    "next:build": "next build",
    "test": "vitest run",
    "test:quality": "tsx scripts/run-unified-quality-gate.ts",
    "test:reality": "tsx scripts/run-core-reality-gate.ts",
    "test:trend": "tsx scripts/run-quality-trend-baseline.ts",
    "test:determinism": "tsx scripts/run-determinism-boundary-audit.ts",
    "test:temporal": "tsx scripts/run-temporal-semantics-audit.ts",
    "test:calibration": "tsx scripts/run-model-calibration-audit.ts",
    "test:repository": "vitest run tests/repository/repositoryReleaseConsistency.test.ts",
    "test:llm-boundary": "vitest run tests/core/llmBoundary tests/scripts/llmBoundaryHarness.test.ts",
    "test:llm-quality": "tsx scripts/run-llm-boundary-quality-gate.ts",
    "test:security": "tsx scripts/run-dependency-security-gate.ts",
    "export:llm-harness": "tsx scripts/export-llm-boundary-harness.ts",
    "rc:verify": "tsx scripts/run-core-reality-gate.ts && tsx scripts/run-unified-quality-gate.ts && tsx scripts/run-quality-trend-baseline.ts && tsx scripts/run-determinism-boundary-audit.ts && tsx scripts/run-temporal-semantics-audit.ts && tsx scripts/run-model-calibration-audit.ts && tsx scripts/export-llm-boundary-harness.ts && tsx scripts/run-llm-boundary-quality-gate.ts && vitest run tests/repository/repositoryReleaseConsistency.test.ts",
    "demo:physics": "tsx src/core/demo/physicsDemo.ts",
    "demo:simulation": "tsx src/core/demo/simulationDemo.ts",
    "demo:trace": "tsx src/core/demo/traceReplayDemo.ts",
    "demo:service": "tsx src/services/demo/characterPhysicsServiceDemo.ts"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  }
}
