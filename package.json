{
  "name": "character-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "next:dev": "next dev",
    "next:build": "next build",
    "test": "vitest run",
    "test:quality": "tsx scripts/run-unified-quality-gate.ts",
    "test:reality": "tsx scripts/run-core-reality-gate.ts",
    "test:trend": "tsx scripts/run-quality-trend-baseline.ts",
    "rc:verify": "tsx scripts/run-core-reality-gate.ts && tsx scripts/run-unified-quality-gate.ts && tsx scripts/run-quality-trend-baseline.ts",
    "demo:physics": "tsx src/core/demo/physicsDemo.ts",
    "demo:simulation": "tsx src/core/demo/simulationDemo.ts",
    "demo:trace": "tsx src/core/demo/traceReplayDemo.ts",
    "demo:service": "tsx src/services/demo/characterPhysicsServiceDemo.ts",
    "demo:hackathon": "tsx demo/server.ts"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
